---
interface Props {
    lng: number;
    lat: number;
    zoom: number;
}

const { lng, lat, zoom } = Astro.props;
---

<div id="map" data-lng={lng} data-lat={lat} data-zoom={zoom}></div>

<style>
    #map {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 100%;
        background-color: #1a1a1a;
    }
</style>

<script>
    import mapboxgl from "mapbox-gl";

    // Use standard Astro import for environment variables
    // In Astro, env vars must be prefixed with PUBLIC_ to be exposed client-side
    const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
    if (!token) {
        console.error("PUBLIC_MAPBOX_TOKEN is missing from your .env file!");
    }
    mapboxgl.accessToken = token;

    const mapContainer = document.getElementById("map");

    if (mapContainer) {
        const lng = parseFloat(mapContainer.dataset.lng || "-73.935242");
        const lat = parseFloat(mapContainer.dataset.lat || "40.730610");
        const zoom = parseFloat(mapContainer.dataset.zoom || "11");

        const map = new mapboxgl.Map({
            container: "map",
            style: "mapbox://styles/mapbox/light-v11", // Standard light atlas aesthetic
            center: [lng, lat],
            zoom: zoom,
        });

        map.on("load", () => {
            console.log("Mapbox loaded successfully");
            // Future logic: Add 3D buildings layer or GeoJSON sources here
        });

        // We can expose the map to the window object so other scripts (like our IntersectionObserver in index.astro) can trigger flyTo()
        (window as any).atlasMap = map;
    }
</script>
