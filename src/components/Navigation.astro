---
// Burgundy header bar — Atlas of Urban Tech style
---

<header class="site-header">
    <div class="header-inner">
        <a href="/" class="brand">The <strong>Atlas</strong> of NYC AV Futures</a>

        <nav class="nav-links">
            <a href="/about">About the Project</a>
            <a href="/research">The Research</a>
            <a href="/#map-section">Explore Map</a>
        </nav>
    </div>
</header>

<style>
    .site-header {
        background-color: #AA142D;
        padding: 1rem 0;
        width: 100%;
    }

    .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .brand {
        font-family: var(--font-sans);
        font-size: 1.2rem;
        font-weight: 600;
        color: #fff;
        text-decoration: none;
        white-space: nowrap;
    }

    .brand strong {
        font-size: 1.5rem;
        font-weight: 800;
    }

    .brand:hover {
        text-decoration: none;
        color: #fff;
    }

    .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .nav-links a {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        text-decoration: none;
    }

    .nav-links a:hover {
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .header-inner {
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .nav-links {
            flex-wrap: wrap;
            justify-content: center;
        }
    }
</style>
