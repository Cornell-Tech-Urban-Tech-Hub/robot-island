---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
    const caseStudies = await getCollection("case-studies");
    return caseStudies.map((study) => ({
        params: { slug: study.slug },
        props: { study },
    }));
}

const { study } = Astro.props;
const { Content } = await study.render();
const allCaseStudies = await getCollection("case-studies");
---

<Layout title={study.data.title}>
    <main class="case-detail">
        <section
            class="hero-image"
            style={study.data.image
                ? `background-image: url('/${study.data.image}')`
                : "background-color: #2c3e50"}
        >
            <div class="hero-overlay">
                <div class="container">
                    <a href="/" class="back-link">&larr; Back to Atlas</a>
                    <h1><span>{study.data.title}</span></h1>
                    {study.data.author && (
                        <p class="author">By {study.data.author}</p>
                    )}
                </div>
            </div>
        </section>

        <section class="detail-map-section">
            <div class="container">
                <div
                    id="detail-map"
                    data-current-geojson={study.data.geojson}
                    data-current-slug={study.slug}
                ></div>
            </div>
        </section>

        <article class="content-body">
            <Content />
        </article>

        <Footer />
    </main>

    <script id="all-studies-data" type="application/json" set:html={JSON.stringify(allCaseStudies.map(s => ({ slug: s.slug, geojson: s.data.geojson, name: s.data.title })))} />
</Layout>

<style>
    /* Hero Image Section */
    .hero-image {
        position: relative;
        min-height: 300px;
        background-size: cover;
        background-position: center;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.7) 0%,
            rgba(0, 0, 0, 0.2) 60%,
            rgba(0, 0, 0, 0.1) 100%
        );
    }

    .hero-overlay .container {
        position: relative;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        min-height: 300px;
    }

    .back-link {
        position: absolute;
        top: 2rem;
        left: 2rem;
        color: white;
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        display: inline-block;
    }

    .back-link:hover {
        text-decoration: underline;
    }

    h1 {
        color: white;
        font-family: var(--font-sans);
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    h1 span {
        background: white;
        color: #333;
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
        padding: 0.15em 0.4em;
        line-height: 1.5;
        box-shadow: 0.4em 0 0 white, -0.4em 0 0 white;
    }

    .author {
        color: white;
        font-family: var(--font-sans);
        font-size: 1rem;
        margin-top: 1rem;
        opacity: 0.9;
    }

    /* Map Section */
    .detail-map-section {
        padding: 3rem 0;
    }

    .detail-map-section .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    #detail-map {
        width: 100%;
        height: 400px;
        border-radius: 4px;
        overflow: hidden;
    }

    /* Content Body */
    .content-body {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
    }

    .content-body :global(h2) {
        margin-top: 2.5rem;
        font-size: 1.8rem;
        font-family: var(--font-sans);
    }

    .content-body :global(h3) {
        margin-top: 2rem;
        font-size: 1.4rem;
        font-family: var(--font-sans);
    }

    .content-body :global(p) {
        font-family: Georgia, serif;
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .content-body :global(ul),
    .content-body :global(ol) {
        padding-left: 2rem;
        font-family: Georgia, serif;
        margin-bottom: 1.5rem;
    }

    .content-body :global(li) {
        margin-bottom: 0.5rem;
    }

    .content-body :global(blockquote) {
        border-left: 4px solid var(--color-accent);
        padding: 1.5rem 2rem;
        font-style: italic;
        background: var(--color-bg-white);
        margin: 2rem 0;
        font-size: 1.1rem;
    }

    .content-body :global(strong) {
        font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-image {
            min-height: 220px;
        }

        .hero-overlay .container h1 {
            font-size: 1.6rem;
        }

        .detail-map {
            height: 300px;
        }

        .detail-map-section .container {
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .content-body {
            padding: 1.5rem 1rem 3rem;
        }
    }

    @media (max-width: 480px) {
        .hero-image {
            min-height: 180px;
        }

        .hero-overlay .container h1 {
            font-size: 1.3rem;
        }

        .detail-map {
            height: 250px;
        }

        .content-body {
            padding: 1rem 0.75rem 2rem;
        }
    }
</style>

<script>
    import mapboxgl from "mapbox-gl";

    const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
    mapboxgl.accessToken = token;

    function initDetailMap() {
        const mapEl = document.getElementById("detail-map");
        if (!mapEl) return;

        const currentGeojson = mapEl.dataset.currentGeojson;
        const currentSlug = mapEl.dataset.currentSlug;

        // Parse all studies data
        const allStudiesEl = document.getElementById("all-studies-data");
        if (!allStudiesEl) return;
        const allStudies = JSON.parse(allStudiesEl.textContent || "[]");

        const map = new mapboxgl.Map({
            container: "detail-map",
            style: "mapbox://styles/mapbox/light-v11",
            center: [-73.935242, 40.73061],
            zoom: 11,
        });

        const hoverPopup = new mapboxgl.Popup({
            closeButton: false,
            closeOnClick: false,
        });

        map.on("load", async () => {
            // Fetch ALL geojson files
            const allFeatures: any[] = [];
            for (const study of allStudies) {
                try {
                    const res = await fetch("/" + study.geojson);
                    const data = await res.json();
                    if (data && data.features) {
                        data.features.forEach((f: any) => {
                            allFeatures.push({
                                ...f,
                                properties: {
                                    ...f.properties,
                                    slug: study.slug,
                                    name: f.properties?.name || study.name,
                                },
                            });
                        });
                    }
                } catch (e) {
                    console.error("Error fetching", study.geojson, e);
                }
            }

            // Add all-boundaries source (gray)
            map.addSource("all-boundaries", {
                type: "geojson",
                data: { type: "FeatureCollection", features: allFeatures },
            });

            map.addLayer({
                id: "all-boundaries-fill",
                type: "fill",
                source: "all-boundaries",
                paint: { "fill-color": "#888", "fill-opacity": 0.15 },
            });

            map.addLayer({
                id: "all-boundaries-line",
                type: "line",
                source: "all-boundaries",
                paint: { "line-color": "#888", "line-width": 1 },
            });

            // Add active boundary (accent color) — just the current case study features
            const activeFeatures = allFeatures.filter(
                (f: any) => f.properties.slug === currentSlug,
            );
            map.addSource("active-boundary", {
                type: "geojson",
                data: {
                    type: "FeatureCollection",
                    features: activeFeatures,
                },
            });

            map.addLayer({
                id: "active-boundary-fill",
                type: "fill",
                source: "active-boundary",
                paint: { "fill-color": "#AA142D", "fill-opacity": 0.4 },
            });

            map.addLayer({
                id: "active-boundary-line",
                type: "line",
                source: "active-boundary",
                paint: { "line-color": "#AA142D", "line-width": 3 },
            });

            // Fit bounds to current case study
            if (activeFeatures.length > 0) {
                const bounds = new mapboxgl.LngLatBounds();
                const extractCoords = (coords: any) => {
                    if (typeof coords[0] === "number")
                        bounds.extend([coords[0], coords[1]]);
                    else coords.forEach(extractCoords);
                };
                activeFeatures.forEach((f: any) => {
                    if (f.geometry?.coordinates)
                        extractCoords(f.geometry.coordinates);
                });
                map.fitBounds(bounds, {
                    padding: {
                        top: 80,
                        bottom: 80,
                        left: 80,
                        right: 80,
                    },
                    maxZoom: 15,
                });
            }

            // Hover on non-active boundaries
            map.on("mousemove", "all-boundaries-fill", (e: any) => {
                if (e.features?.length > 0) {
                    const feature = e.features[0];
                    if (feature.properties.slug === currentSlug) {
                        map.getCanvas().style.cursor = "";
                        hoverPopup.remove();
                        return;
                    }
                    map.getCanvas().style.cursor = "pointer";
                    hoverPopup
                        .setLngLat(e.lngLat)
                        .setHTML(feature.properties.name)
                        .addTo(map);
                }
            });

            map.on("mouseleave", "all-boundaries-fill", () => {
                map.getCanvas().style.cursor = "";
                hoverPopup.remove();
            });

            // Click to navigate
            map.on("click", "all-boundaries-fill", (e: any) => {
                if (e.features?.length > 0) {
                    const feature = e.features[0];
                    if (feature.properties.slug !== currentSlug) {
                        window.location.href = `/case-studies/${feature.properties.slug}`;
                    }
                }
            });
        });
    }

    // Initialize
    document.addEventListener("astro:page-load", initDetailMap);
    if (
        document.readyState === "complete" ||
        document.readyState === "interactive"
    ) {
        initDetailMap();
    } else {
        document.addEventListener("DOMContentLoaded", initDetailMap);
    }
</script>
