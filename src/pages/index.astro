---
import Layout from "../layouts/Layout.astro";
import SplitLayout from "../layouts/SplitLayout.astro";
import { getCollection } from "astro:content";

const allCaseStudies = await getCollection("case-studies");

// Initial coordinates for NYC
const defaultLng = -73.935242;
const defaultLat = 40.73061;
const defaultZoom = 11;
---

<Layout title="NYC AV Atlas">
	<SplitLayout
		initialLng={defaultLng}
		initialLat={defaultLat}
		initialZoom={defaultZoom}
	>
		<div class="atlas-content">
			<header class="atlas-header">
				<h1>
					The <span class="highlight-red">Atlas</span><br />of NYC AV
					Futures
				</h1>
				<p>
					A global atlas of case studies of tech-enabled urban
					districts and municipal digital masterplans, tailored for
					Autonomous Vehicles in NYC.
				</p>
			</header>

			<div class="case-studies-list" id="case-studies-container">
				{
					allCaseStudies.map((study, index) => (
						<article
							class="case-study-card"
							data-geojson={study.data.geojson}
							data-index={index}
							id={`study-${index}`}
						>
							<div class="card-meta">Case Study {index + 1}</div>
							<h2>{study.data.title}</h2>
							<p class="description">{study.data.description}</p>
							{study.data.author && (
								<p class="author">By {study.data.author}</p>
							)}

							<a
								href={`/case-studies/${study.slug}`}
								class="btn-outline btn-red mt-2"
							>
								Read Full Analysis
							</a>
						</article>
					))
				}

				{/* Placeholder if no studies found */}
				{
					allCaseStudies.length === 0 && (
						<div class="empty-state">
							<p>
								No case studies found. Add markdown files to{" "}
								<code>src/content/case-studies/</code>.
							</p>
						</div>
					)
				}
			</div>

			<footer class="atlas-footer text-center mt-5 pt-3">
				<p>A research project exploring urban tech futures.</p>
			</footer>
		</div>
	</SplitLayout>
</Layout>

<style>
	.atlas-content {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-bottom: 50vh; /* Allow scrolling past the last item */
	}

	.atlas-header {
		padding: 1rem 0 3rem;
	}

	.atlas-header h1 {
		font-size: 3rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		color: #333;
		letter-spacing: -0.02em;
	}

	.highlight-red {
		color: var(--color-accent);
		font-size: 4rem;
	}

	.atlas-header p {
		font-size: 1.25rem;
		line-height: 1.6;
		color: #444;
		font-family: var(--font-serif);
	}

	.case-studies-list {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.case-study-card {
		padding: 2.5rem;
		background-color: var(--color-bg-white);
		border: 1px solid var(--color-border);
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
		position: relative;
		overflow: hidden;
	}

	.case-study-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.05);
	}

	/* The active state when scrolling highlights the card */
	.case-study-card.is-active {
		border-left: 4px solid var(--color-accent);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08); /* slight highlight */
	}

	.card-meta {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-accent);
		margin-bottom: 1.25rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.card-meta::before {
		content: "";
		display: inline-block;
		width: 20px;
		height: 2px;
		background-color: var(--color-accent);
	}

	.case-study-card h2 {
		font-family: var(--font-sans);
		font-size: 1.75rem;
		line-height: 1.2;
		color: #111;
		margin-bottom: 1.25rem;
	}

	.description {
		font-family: var(--font-serif);
		font-size: 1rem;
		line-height: 1.7;
		color: #555;
		margin-bottom: 2rem;
	}

	.author {
		font-family: var(--font-sans);
		font-size: 0.85rem;
		color: #888;
		margin-bottom: 1.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.mt-2 {
		margin-top: 1rem;
	}

	.mt-5 {
		margin-top: 4rem;
	}

	.pt-3 {
		padding-top: 2rem;
	}

	.atlas-footer {
		border-top: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: 0.9rem;
		font-family: var(--font-sans);
	}
</style>

<script>
	// Client-side code to handle map updates as user scrolls through cards
	let globalBounds = { minLng: 180, minLat: 90, maxLng: -180, maxLat: -90 };

	async function loadAllGeometries() {
		const map = (window as any).atlasMap;
		if (!map) return;

		const cards = document.querySelectorAll(".case-study-card");
		const urls = Array.from(cards)
			.map((c: any) => c.dataset.geojson)
			.filter(Boolean);

		if (urls.length === 0) return;

		try {
			const responses = await Promise.all(
				urls.map((url) => fetch("/" + url)),
			);
			const dataArrays = await Promise.all(
				responses.map((res) => res.json()),
			);

			const extractCoords = (coords: any) => {
				if (typeof coords[0] === "number") {
					globalBounds.minLng = Math.min(
						globalBounds.minLng,
						coords[0],
					);
					globalBounds.maxLng = Math.max(
						globalBounds.maxLng,
						coords[0],
					);
					globalBounds.minLat = Math.min(
						globalBounds.minLat,
						coords[1],
					);
					globalBounds.maxLat = Math.max(
						globalBounds.maxLat,
						coords[1],
					);
				} else {
					coords.forEach(extractCoords);
				}
			};

			const allFeatures = dataArrays.flatMap((data) => {
				if (data && data.features) {
					data.features.forEach((f: any) => {
						if (f.geometry && f.geometry.coordinates) {
							extractCoords(f.geometry.coordinates);
						}
					});
					return data.features;
				}
				return [];
			});

			const sourceId = "all-case-studies";
			const geojsonData = {
				type: "FeatureCollection",
				features: allFeatures,
			};

			if (!map.getSource(sourceId)) {
				map.addSource(sourceId, {
					type: "geojson",
					data: geojsonData,
				});

				map.addLayer({
					id: sourceId + "-fill",
					type: "fill",
					source: sourceId,
					paint: {
						"fill-color": "#888888", // Grey for inactive base layer
						"fill-opacity": 0.2,
					},
				});

				map.addLayer({
					id: sourceId + "-line",
					type: "line",
					source: sourceId,
					paint: {
						"line-color": "#888888",
						"line-width": 1,
					},
				});
			}

			// Fly to global bounds initially
			flyToGlobalBounds();
		} catch (e) {
			console.error("Error loading all GeoJSONs:", e);
		}
	}

	function flyToGlobalBounds() {
		const map = (window as any).atlasMap;
		if (!map || globalBounds.minLng === 180) return;

		map.fitBounds(
			[
				[globalBounds.minLng, globalBounds.minLat],
				[globalBounds.maxLng, globalBounds.maxLat],
			],
			{
				padding: {
					top: 50,
					bottom: 50,
					left: 50,
					right: 50,
				},
				maxZoom: 15,
				duration: 2000,
			},
		);

		// clear active case study if any
		if (map.getSource("active-case-study")) {
			map.getSource("active-case-study").setData({
				type: "FeatureCollection",
				features: [],
			});
		}
	}

	function initializeObserver() {
		const cards = document.querySelectorAll(".case-study-card");
		const header = document.querySelector(".atlas-header");

		if (!cards.length) return;

		// Card observer triggering when a card hits the middle of viewport
		const observerOptions = {
			root: document.querySelector(".content-scroll-area"),
			rootMargin: "-40% 0px -40% 0px",
			threshold: 0,
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					// Visual update
					cards.forEach((c) => c.classList.remove("is-active"));
					entry.target.classList.add("is-active");

					// Map update
					const url = (entry.target as HTMLElement).dataset.geojson;
					if (url) {
						updateMapWithGeoJSON(url);
					}
				}
			});
		}, observerOptions);

		cards.forEach((card) => observer.observe(card));

		// Header observer: triggers global reset when scrolling back to top
		if (header) {
			const headerObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						// If header is substantially intersecting, reset to global bounds
						if (entry.isIntersecting) {
							cards.forEach((c) =>
								c.classList.remove("is-active"),
							);
							flyToGlobalBounds();
						}
					});
				},
				{
					root: document.querySelector(".content-scroll-area"),
					rootMargin: "0px",
					threshold: 0.2, // Trigger earlier when scrolling up
				},
			);
			headerObserver.observe(header);
		}
	}

	async function updateMapWithGeoJSON(geoJsonUrl: string) {
		const map = (window as any).atlasMap;
		if (!map) return;

		try {
			const response = await fetch("/" + geoJsonUrl);
			const data = await response.json();

			if (data && data.features && data.features.length > 0) {
				let minLng = 180,
					minLat = 90,
					maxLng = -180,
					maxLat = -90;

				const extractCoords = (coords: any) => {
					if (typeof coords[0] === "number") {
						minLng = Math.min(minLng, coords[0]);
						maxLng = Math.max(maxLng, coords[0]);
						minLat = Math.min(minLat, coords[1]);
						maxLat = Math.max(maxLat, coords[1]);
					} else {
						coords.forEach(extractCoords);
					}
				};

				data.features.forEach((f: any) => {
					if (f.geometry && f.geometry.coordinates) {
						extractCoords(f.geometry.coordinates);
					}
				});

				if (minLng !== 180) {
					map.fitBounds(
						[
							[minLng, minLat],
							[maxLng, maxLat],
						],
						{
							padding: {
								top: 50,
								bottom: 50,
								left: 50,
								right: 50,
							},
							maxZoom: 15,
							duration: 2000,
						},
					);
				}

				updateMapLayer(map, data);
			}
		} catch (e) {
			console.error("Error loading GeoJSON for map:", e);
		}
	}

	function updateMapLayer(map: any, geojsonData: any) {
		const sourceId = "active-case-study";

		if (map.getSource(sourceId)) {
			map.getSource(sourceId).setData(geojsonData);
		} else {
			map.addSource(sourceId, {
				type: "geojson",
				data: geojsonData,
			});

			map.addLayer({
				id: sourceId + "-fill",
				type: "fill",
				source: sourceId,
				paint: {
					"fill-color": "#c8102e", // Atlas Red Highlight
					"fill-opacity": 0.4,
				},
			});

			map.addLayer({
				id: sourceId + "-line",
				type: "line",
				source: sourceId,
				paint: {
					"line-color": "#c8102e",
					"line-width": 3,
				},
			});
		}
	}

	function init() {
		// Ensure Mapbox object is fully ready before we add sources
		const checkMap = setInterval(() => {
			if ((window as any).atlasMap && (window as any).atlasMap.loaded()) {
				clearInterval(checkMap);
				loadAllGeometries();
				initializeObserver();
			} else if ((window as any).atlasMap) {
				clearInterval(checkMap);
				(window as any).atlasMap.on("load", () => {
					loadAllGeometries();
					initializeObserver();
				});
			}
		}, 100);
	}

	document.addEventListener("astro:page-load", init);

	if (
		document.readyState === "complete" ||
		document.readyState === "interactive"
	) {
		init();
	} else {
		document.addEventListener("DOMContentLoaded", init);
	}
</script>
