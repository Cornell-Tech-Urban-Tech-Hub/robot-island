---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const allCaseStudies = await getCollection("case-studies");
---

<Layout title="NYC AV Atlas">
	<main class="atlas-home">
		<section class="hero">
			<div class="container">
				<h1>The <span class="accent">Atlas</span> of NYC AV Futures</h1>
				<p class="subtitle">
					A global atlas of case studies of tech-enabled urban districts
					and municipal digital masterplans, tailored for Autonomous
					Vehicles in NYC.
				</p>
			</div>
		</section>

		<section class="map-section" id="map-section">
			<div class="map-container" id="map"></div>
		</section>

		<section class="case-studies">
			<div class="container">
				<h2>Case Studies</h2>
				<div class="card-grid">
					{allCaseStudies.map((study) => (
						<a
							href={`/case-studies/${study.slug}`}
							class="card-link"
							data-geojson={study.data.geojson}
							data-slug={study.slug}
						>
							<article class="case-card">
								{study.data.image && (
									<div
										class="card-image"
										style={`background-image: url('/${study.data.image}')`}
									></div>
								)}
								<div class="card-content">
									<h3>{study.data.title}</h3>
									<p class="card-description">{study.data.description}</p>
									{study.data.author && (
										<span class="card-author">By {study.data.author}</span>
									)}
									<span class="card-read-more">Read more &rarr;</span>
								</div>
							</article>
						</a>
					))}
				</div>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		padding: 4rem 0 3rem;
	}

	.hero .container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.hero h1 {
		font-family: var(--font-sans);
		font-size: 2.4rem;
		font-weight: 700;
		color: #333;
		margin-bottom: 1rem;
	}

	.hero h1 .accent {
		color: var(--color-accent);
	}

	.hero .subtitle {
		font-family: var(--font-serif);
		font-size: 1.1rem;
		color: #555;
		max-width: 600px;
		line-height: 1.6;
	}

	/* Map Section */
	.map-section {
		width: 100%;
	}

	.map-container {
		width: 100%;
		height: 500px;
	}

	/* Case Studies Section */
	.case-studies {
		padding: 4rem 0;
	}

	.case-studies .container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.case-studies h2 {
		font-family: var(--font-sans);
		font-size: 1.8rem;
		margin-bottom: 2rem;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
	}

	/* Card Link */
	a.card-link {
		text-decoration: none;
		color: inherit;
	}

	a.card-link:hover {
		text-decoration: none;
	}

	/* Card Design */
	.case-card {
		background: #fff;
		border-radius: 4px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	a.card-link:hover .case-card {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	.card-image {
		height: 200px;
		background-size: cover;
		background-position: center;
	}

	.card-content {
		padding: 1.5rem;
	}

	.card-content h3 {
		font-family: var(--font-sans);
		font-size: 1.2rem;
		font-weight: 700;
		color: #333;
		margin-bottom: 0.75rem;
	}

	.card-description {
		font-family: var(--font-serif);
		font-size: 0.9rem;
		color: #555;
		line-height: 1.5;
		margin-bottom: 1rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-author {
		font-family: var(--font-sans);
		font-size: 0.8rem;
		color: #999;
		display: block;
		margin-bottom: 0.75rem;
	}

	.card-read-more {
		font-family: var(--font-sans);
		font-size: 0.85rem;
		color: var(--color-accent);
		font-weight: 600;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero {
			padding: 2.5rem 0 2rem;
		}

		.hero h1 {
			font-size: 1.8rem;
		}

		.hero .subtitle {
			font-size: 1rem;
		}

		.map-container {
			height: 350px;
		}

		.case-studies {
			padding: 2.5rem 0;
		}

		.card-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.map-container {
			height: 280px;
		}

		.hero h1 {
			font-size: 1.5rem;
		}
	}
</style>

<script>
	import mapboxgl from "mapbox-gl";

	const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
	if (!token) {
		console.error("PUBLIC_MAPBOX_TOKEN is missing from your .env file!");
	}
	mapboxgl.accessToken = token;

	function initMap() {
		const mapContainer = document.getElementById("map");
		if (!mapContainer) return;

		const map = new mapboxgl.Map({
			container: "map",
			style: "mapbox://styles/mapbox/light-v11",
			center: [-73.935242, 40.73061],
			zoom: 11,
		});

		(window as any).atlasMap = map;

		// Single reusable popup for hover
		const hoverPopup = new mapboxgl.Popup({
			closeButton: false,
			closeOnClick: false,
		});

		map.on("load", async () => {
			// Build slug-to-geojson mapping from card elements
			const cards = document.querySelectorAll("a.card-link");
			const slugToGeojson: Record<string, string> = {};

			cards.forEach((card) => {
				const el = card as HTMLElement;
				const slug = el.dataset.slug;
				const geojsonPath = el.dataset.geojson;
				if (slug && geojsonPath) {
					slugToGeojson[geojsonPath] = slug;
				}
			});

			// Fetch all geojson files and merge into one FeatureCollection
			const geojsonPaths = Object.keys(slugToGeojson);
			if (geojsonPaths.length === 0) return;

			try {
				const responses = await Promise.all(
					geojsonPaths.map((path) => fetch("/" + path)),
				);
				const dataArrays = await Promise.all(
					responses.map((res) => res.json()),
				);

				const allFeatures: any[] = [];

				dataArrays.forEach((data, i) => {
					const geojsonPath = geojsonPaths[i];
					const slug = slugToGeojson[geojsonPath];

					if (data && data.features) {
						data.features.forEach((feature: any) => {
							// Add slug and preserve name property
							const enrichedFeature = {
								...feature,
								properties: {
									...feature.properties,
									slug: slug,
									name: feature.properties?.name || slug,
								},
							};
							allFeatures.push(enrichedFeature);
						});
					}
				});

				const mergedCollection = {
					type: "FeatureCollection" as const,
					features: allFeatures,
				};

				// Add source
				map.addSource("all-boundaries", {
					type: "geojson",
					data: mergedCollection,
				});

				// Base fill layer
				map.addLayer({
					id: "boundaries-fill",
					type: "fill",
					source: "all-boundaries",
					paint: {
						"fill-color": "#AA142D",
						"fill-opacity": 0.15,
					},
				});

				// Base line layer
				map.addLayer({
					id: "boundaries-line",
					type: "line",
					source: "all-boundaries",
					paint: {
						"line-color": "#AA142D",
						"line-width": 1,
					},
				});

				// Hover fill layer (initially matches nothing)
				map.addLayer({
					id: "boundaries-fill-hover",
					type: "fill",
					source: "all-boundaries",
					paint: {
						"fill-color": "#AA142D",
						"fill-opacity": 0.4,
					},
					filter: ["==", ["get", "slug"], ""],
				});

				// Hover line layer (initially matches nothing)
				map.addLayer({
					id: "boundaries-line-hover",
					type: "line",
					source: "all-boundaries",
					paint: {
						"line-color": "#AA142D",
						"line-width": 3,
					},
					filter: ["==", ["get", "slug"], ""],
				});

				// Fit bounds to all features
				if (allFeatures.length > 0) {
					const bounds = new mapboxgl.LngLatBounds();

					const extractCoords = (coords: any) => {
						if (
							typeof coords[0] === "number" &&
							typeof coords[1] === "number"
						) {
							bounds.extend([coords[0], coords[1]]);
						} else {
							coords.forEach(extractCoords);
						}
					};

					allFeatures.forEach((feature: any) => {
						if (
							feature.geometry &&
							feature.geometry.coordinates
						) {
							extractCoords(feature.geometry.coordinates);
						}
					});

					map.fitBounds(bounds, {
						padding: {
							top: 50,
							bottom: 50,
							left: 50,
							right: 50,
						},
						maxZoom: 14,
					});
				}

				// Hover behavior
				map.on("mousemove", "boundaries-fill", (e: any) => {
					if (e.features && e.features.length > 0) {
						const feature = e.features[0];
						const slug = feature.properties.slug;
						const name = feature.properties.name;

						// Update hover layer filters
						map.setFilter("boundaries-fill-hover", [
							"==",
							["get", "slug"],
							slug,
						]);
						map.setFilter("boundaries-line-hover", [
							"==",
							["get", "slug"],
							slug,
						]);

						// Change cursor
						map.getCanvas().style.cursor = "pointer";

						// Show popup
						hoverPopup
							.setLngLat(e.lngLat)
							.setHTML(name)
							.addTo(map);
					}
				});

				map.on("mouseleave", "boundaries-fill", () => {
					// Reset hover filters
					map.setFilter("boundaries-fill-hover", [
						"==",
						["get", "slug"],
						"",
					]);
					map.setFilter("boundaries-line-hover", [
						"==",
						["get", "slug"],
						"",
					]);

					// Reset cursor
					map.getCanvas().style.cursor = "";

					// Remove popup
					hoverPopup.remove();
				});

				// Click behavior
				map.on("click", "boundaries-fill", (e: any) => {
					if (e.features && e.features.length > 0) {
						const feature = e.features[0];
						const slug = feature.properties.slug;
						window.location.href = `/case-studies/${slug}`;
					}
				});
			} catch (err) {
				console.error("Error loading GeoJSON data:", err);
			}
		});
	}

	// Initialize on page load
	document.addEventListener("astro:page-load", initMap);

	if (
		document.readyState === "complete" ||
		document.readyState === "interactive"
	) {
		initMap();
	} else {
		document.addEventListener("DOMContentLoaded", initMap);
	}
</script>
