---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allCaseStudies = await getCollection("case-studies");
---

<Layout title="Robot Island" hideNav={true}>
	<main class="atlas-home">
		<div class="content-side">
			<section class="hero">
				<h1><span class="accent">Robot</span> Island</h1>
				<p class="subtitle">Autonomous vehicle futures on Roosevelt Island</p>
			</section>

			<section class="case-studies">
				<div class="card-grid">
					{allCaseStudies.map((study) => {
						const featuredMedia = study.data.media?.find(m => m.featured);
						const cardImage = featuredMedia?.file;
						return (
							<a
								href={`/case-studies/${study.slug}`}
								class="card-link"
								data-geojson={study.data.geojson}
								data-slug={study.slug}
							>
								<article class="case-card">
									<div
										class="card-image"
										style={cardImage ? `background-image: url('${cardImage.startsWith('http') ? cardImage : '/' + cardImage}')` : 'background-color: #334155'}
									>
										<span class={`card-type card-type--${study.data.type}`}>{study.data.type}</span>
									</div>
									<div class="card-content">
										<p class="card-place">📍 {study.data.place}</p>
										<h3>{study.data.concept}</h3>
									</div>
								</article>
							</a>
						);
					})}
				</div>
			</section>

		</div>
		<div class="map-side">
			<div class="map-container" id="map"></div>
		</div>
	</main>
</Layout>

<style>
	/* Split Layout */
	.atlas-home {
		display: flex;
		height: 100vh;
		overflow: hidden;
	}

	.content-side {
		width: 66.666%;
		overflow-y: auto;
		padding: 2rem;
		background: var(--color-header);
	}

	.map-side {
		width: 33.333%;
		position: relative;
	}

	.map-side .map-container {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
	}

	/* Hero Section */
	.hero {
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-family: var(--font-sans);
		font-size: 2.4rem;
		font-weight: 700;
		color: #fff;
		margin-bottom: 1rem;
	}

	.hero h1 .accent {
		color: var(--color-accent);
	}

	.hero .subtitle {
		font-family: var(--font-serif);
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.7);
		max-width: 600px;
		line-height: 1.6;
	}

	/* Card Grid */
	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 1.25rem;
	}

	/* Card Link */
	a.card-link {
		text-decoration: none;
		color: inherit;
		display: flex;
	}

	a.card-link:hover {
		text-decoration: none;
	}

	/* Card Design */
	.case-card {
		background: #fff;
		border-radius: 6px;
		overflow: hidden;
		transition: transform 0.25s ease, box-shadow 0.25s ease;
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	a.card-link:hover .case-card {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
	}

	.card-image {
		height: 140px;
		background-size: cover;
		background-position: center;
		position: relative;
	}

	.card-content {
		padding: 1rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.card-content h3 {
		font-family: var(--font-sans);
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text-primary);
		margin-bottom: 0.5rem;
		line-height: 1.3;
	}

	.card-place {
		font-family: var(--font-sans);
		font-size: 0.8rem;
		color: var(--color-text-secondary);
		margin-bottom: 0.5rem;
	}

	.card-type {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		display: inline-block;
		font-family: var(--font-sans);
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.25em 0.6em;
		border-radius: 3px;
	}

	.card-type--passenger {
		background: #DBEAFE;
		color: #1E40AF;
	}

	.card-type--freight {
		background: #FEF3C7;
		color: #92400E;
	}

	.card-type--service {
		background: #D1FAE5;
		color: #065F46;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.atlas-home {
			flex-direction: column;
			height: auto;
			overflow: visible;
		}

		.content-side {
			width: 100%;
			overflow-y: visible;
		}

		.map-side {
			width: 100%;
			height: 400px;
			position: relative;
			order: -1;
		}

		.hero h1 {
			font-size: 1.8rem;
		}

		.hero .subtitle {
			font-size: 1rem;
		}

		.card-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.map-side {
			height: 300px;
		}

		.hero h1 {
			font-size: 1.5rem;
		}
	}
</style>

<script>
	import mapboxgl from "mapbox-gl";

	const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
	if (!token) {
		console.error("PUBLIC_MAPBOX_TOKEN is missing from your .env file!");
	}
	mapboxgl.accessToken = token;

	function initMap() {
		const mapContainer = document.getElementById("map");
		if (!mapContainer) return;

		const map = new mapboxgl.Map({
			container: "map",
			style: "mapbox://styles/mapbox/light-v11",
			center: [-73.950, 40.762],
			zoom: 14,
			bearing: 28,
		});

		(window as any).atlasMap = map;

		// Single reusable popup for hover
		const hoverPopup = new mapboxgl.Popup({
			closeButton: false,
			closeOnClick: false,
		});

		map.on("load", async () => {
			// Build slug-to-geojson mapping from card elements
			const cards = document.querySelectorAll("a.card-link");
			const slugToGeojson: Record<string, string> = {};

			cards.forEach((card) => {
				const el = card as HTMLElement;
				const slug = el.dataset.slug;
				const geojsonPath = el.dataset.geojson;
				if (slug && geojsonPath) {
					slugToGeojson[geojsonPath] = slug;
				}
			});

			// Fetch all geojson files and merge into one FeatureCollection
			const geojsonPaths = Object.keys(slugToGeojson);
			if (geojsonPaths.length === 0) return;

			try {
				const responses = await Promise.all(
					geojsonPaths.map((path) => fetch("/" + path)),
				);
				const dataArrays = await Promise.all(
					responses.map((res) => res.json()),
				);

				const allFeatures: any[] = [];

				dataArrays.forEach((data, i) => {
					const geojsonPath = geojsonPaths[i];
					const slug = slugToGeojson[geojsonPath];

					if (data && data.features) {
						data.features.forEach((feature: any) => {
							const enrichedFeature = {
								...feature,
								properties: {
									...feature.properties,
									slug: slug,
									name: feature.properties?.name || slug,
								},
							};
							allFeatures.push(enrichedFeature);
						});
					}
				});

				const mergedCollection = {
					type: "FeatureCollection" as const,
					features: allFeatures,
				};

				// Add source
				map.addSource("all-boundaries", {
					type: "geojson",
					data: mergedCollection,
				});

				// Base fill layer
				map.addLayer({
					id: "boundaries-fill",
					type: "fill",
					source: "all-boundaries",
					paint: {
						"fill-color": "#0066FF",
						"fill-opacity": 0.15,
					},
				});

				// Base line layer
				map.addLayer({
					id: "boundaries-line",
					type: "line",
					source: "all-boundaries",
					paint: {
						"line-color": "#0066FF",
						"line-width": 1,
					},
				});

				// Hover fill layer (initially matches nothing)
				map.addLayer({
					id: "boundaries-fill-hover",
					type: "fill",
					source: "all-boundaries",
					paint: {
						"fill-color": "#0066FF",
						"fill-opacity": 0.4,
					},
					filter: ["==", ["get", "slug"], ""],
				});

				// Hover line layer (initially matches nothing)
				map.addLayer({
					id: "boundaries-line-hover",
					type: "line",
					source: "all-boundaries",
					paint: {
						"line-color": "#0066FF",
						"line-width": 3,
					},
					filter: ["==", ["get", "slug"], ""],
				});

				// Fit bounds to all features
				if (allFeatures.length > 0) {
					const bounds = new mapboxgl.LngLatBounds();

					const extractCoords = (coords: any) => {
						if (
							typeof coords[0] === "number" &&
							typeof coords[1] === "number"
						) {
							bounds.extend([coords[0], coords[1]]);
						} else {
							coords.forEach(extractCoords);
						}
					};

					allFeatures.forEach((feature: any) => {
						if (
							feature.geometry &&
							feature.geometry.coordinates
						) {
							extractCoords(feature.geometry.coordinates);
						}
					});

					// fitBounds uses an axis-aligned bbox which wastes space
					// when the map is rotated. Fit first, then zoom in to compensate.
					map.fitBounds(bounds, {
						padding: 0,
						bearing: 28,
					});
					map.once("moveend", () => {
						map.zoomTo(map.getZoom() + 1, { duration: 0 });
					});

					// Re-fit on window resize so map adapts to container size changes
					window.addEventListener("resize", () => {
						map.resize();
						map.fitBounds(bounds, {
							padding: 0,
							bearing: 28,
						});
						map.once("moveend", () => {
							map.zoomTo(map.getZoom() + 1, { duration: 0 });
						});
					});
				}

				// Hover behavior
				map.on("mousemove", "boundaries-fill", (e: any) => {
					if (e.features && e.features.length > 0) {
						const feature = e.features[0];
						const slug = feature.properties.slug;
						const name = feature.properties.name;

						// Update hover layer filters
						map.setFilter("boundaries-fill-hover", [
							"==",
							["get", "slug"],
							slug,
						]);
						map.setFilter("boundaries-line-hover", [
							"==",
							["get", "slug"],
							slug,
						]);

						// Change cursor
						map.getCanvas().style.cursor = "pointer";

						// Show popup with name and link
						hoverPopup
							.setLngLat(e.lngLat)
							.setHTML(`<strong>${name}</strong><br><a href="/case-studies/${slug}" style="color:#0066FF;font-size:0.85em;">View case study &rarr;</a>`)
							.addTo(map);
					}
				});

				map.on("mouseleave", "boundaries-fill", () => {
					// Reset hover filters
					map.setFilter("boundaries-fill-hover", [
						"==",
						["get", "slug"],
						"",
					]);
					map.setFilter("boundaries-line-hover", [
						"==",
						["get", "slug"],
						"",
					]);

					// Reset cursor
					map.getCanvas().style.cursor = "";

					// Remove popup
					hoverPopup.remove();
				});

				// Click behavior
				map.on("click", "boundaries-fill", (e: any) => {
					if (e.features && e.features.length > 0) {
						const feature = e.features[0];
						const slug = feature.properties.slug;
						window.location.href = `/case-studies/${slug}`;
					}
				});
			} catch (err) {
				console.error("Error loading GeoJSON data:", err);
			}
		});
	}

	// Initialize on page load
	document.addEventListener("astro:page-load", initMap);

	if (
		document.readyState === "complete" ||
		document.readyState === "interactive"
	) {
		initMap();
	} else {
		document.addEventListener("DOMContentLoaded", initMap);
	}
</script>
